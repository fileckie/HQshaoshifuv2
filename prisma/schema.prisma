// 私域宴请邀请函系统 - 数据库模型
// 支持 SQLite (开发) 和 PostgreSQL (生产)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  address     String
  phone       String
  description String?
  chefName    String?
  chefIntro   String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  banquets    Banquet[]
  tables      Table[]
}

model Table {
  id           String    @id @default(uuid())
  name         String
  type         String
  x            Float
  y            Float
  width        Float
  height       Float
  capacity     Int
  sortOrder    Int       @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  banquets     Banquet[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([type])
  @@index([restaurantId])
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  email       String?
  birthday    String?
  anniversary String?
  company     String?
  position    String?
  level       String   @default("regular")
  tags        String   @default("[]")
  notes       String?
  firstVisit  String?
  totalVisits Int      @default(0)
  totalSpend  Int      @default(0)
  avgSpend    Int      @default(0)
  lastVisit   String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  banquets     Banquet[]
  preferences  CustomerPreference[]
  reminders    Reminder[]
}

model CustomerPreference {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        String
  content     String
  priority    Int      @default(1)
  sourceBanquetId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([customerId])
}

model Banquet {
  id                  String   @id @default(uuid())
  title               String
  date                String
  time                String
  guestCount          Int
  roomName            String
  customerId          String?
  customer            Customer? @relation(fields: [customerId], references: [id])
  tableId             String?
  table               Table?   @relation(fields: [tableId], references: [id])
  hostName            String
  hostPhone           String
  menu                String
  specialDishes       String?
  restaurantId        String
  restaurant          Restaurant @relation(fields: [restaurantId], references: [id])
  bookingChannel      String?
  paymentStatus       String?
  depositAmount       Int?
  dietaryRestrictions String?
  specialRequests     String?
  handoverNotes       String?
  serviceStatus       String   @default("booked")
  notes               String?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  rsvps               RSVP[]
  serviceTasks        ServiceTask[]
  @@index([date])
  @@index([status])
  @@index([customerId])
  @@index([tableId])
}

model RSVP {
  id                  String   @id @default(uuid())
  banquetId           String
  banquet             Banquet  @relation(fields: [banquetId], references: [id], onDelete: Cascade)
  guestName           String
  guestPhone          String?
  status              String   @default("pending")
  attendeeCount       Int      @default(1)
  dietaryRestrictions String?
  message             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@index([banquetId])
}

model ServiceTask {
  id          String   @id @default(uuid())
  banquetId   String
  banquet     Banquet  @relation(fields: [banquetId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String?
  scheduledAt String?
  actualAt    DateTime?
  scriptId    String?
  status      String   @default("pending")
  assignedTo  String?
  completedBy String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([banquetId])
  @@index([status])
}

model ServiceScript {
  id          String   @id @default(uuid())
  category    String
  triggerType String?
  triggerDish String?
  title       String
  content     String
  useCount    Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category])
}

model Reminder {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        String
  title       String
  content     String?
  remindDate  String
  remindTime  String?
  banquetId   String?
  status      String   @default("pending")
  sentAt      DateTime?
  sentChannel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([customerId])
  @@index([status])
  @@index([remindDate])
}

// 当季主推产品库
model Product {
  id          String   @id @default(uuid())
  name        String   // 产品名称
  description String?  // 产品介绍（小字）
  category    String   // 类别：主厨限定串 / 当季时令烧鸟 / 其他
  sortOrder   Int      @default(0) // 排序
  isActive    Boolean  @default(true) // 是否启用
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
}
